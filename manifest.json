{
  "manifest_version": 3,
  "name": "Lockem",
  "version": "1.0.0",
  "description": "Remove distractions from YouTube",

  "permissions": [
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "https://*.youtube.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*"
      ],
      "js": [
        "content/youtube.js"
      ],
      "css": [
        "content/youtube.css"
        ]
    }
  ],

  "action": {
    "default_popup": "popup/popup.html"
  }
}